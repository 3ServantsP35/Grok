// AB4 Entry Gate — 200-Week MA + RSI14 < 35 + Positive Slope
// Implements the AB4 hard-floor entry condition for Rotational AB4 profile.
// Uses 200-week SMA (MTF capable) + RSI(14) + slope confirmation.
// Condition: Price above 200wMA AND RSI14 < 35 AND 200wMA slope > 0.
// This is the structural floor gate before SRI Calibrated Groups confirmation.
// © RizenShine — AB4 Entry layer for CIO SRI engine

//@version=6
indicator("AB4 Entry Gate", shorttitle="AB4 Gate", overlay=true, max_bars_back=2000)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_ma = "200-Week MA"
i_ma_len   = input.int(200, "MA Length", minval=10, maxval=500, group=grp_ma)
i_ma_tf    = input.string("W", "MA Timeframe", 
     options=["Auto (Current)", "1", "3", "5", "15", "30", "45", "60", "120", "180", "240", "D", "W", "M"], 
     group=grp_ma)

grp_rsi = "RSI Gate"
i_rsi_len  = input.int(14, "RSI Length", minval=2, maxval=50, group=grp_rsi)
i_rsi_thresh = input.float(35, "RSI Threshold (below = entry zone)", minval=10, maxval=50, group=grp_rsi)

grp_slope = "Slope Confirmation"
i_slope_len = input.int(20, "Slope Lookback (bars)", minval=5, maxval=100, group=grp_slope)

// ═══════════════════════════════════════════════════════════════
// TIMEFRAME & CALCULATIONS
// ═══════════════════════════════════════════════════════════════
ma_tf = i_ma_tf == "Auto (Current)" ? timeframe.period : i_ma_tf

ma_200w = request.security(syminfo.tickerid, ma_tf, ta.sma(close, i_ma_len))
rsi14   = ta.rsi(close, i_rsi_len)

// Slope: simple delta over lookback (positive = rising)
ma_slope = ma_200w - ma_200w[i_slope_len]

// ═══════════════════════════════════════════════════════════════
// AB4 ENTRY CONDITION
// ═══════════════════════════════════════════════════════════════
ab4_entry = close > ma_200w and rsi14 < i_rsi_thresh and ma_slope > 0

// ═══════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════
plot(ma_200w, "200-Week SMA", color=color.new(color.orange, 0), linewidth=2)
plotshape(ab4_entry, "AB4 Entry", style=shape.triangleup, location=location.belowbar, 
     color=color.new(color.green, 0), size=size.small, text="AB4")

bgcolor(ab4_entry ? color.new(color.green, 88) : na)

// Info table
var table t = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 70))
table.cell(t, 0, 0, "200wMA", text_color=color.gray)
table.cell(t, 1, 0, str.tostring(ma_200w, format.mintick), text_color=color.orange)
table.cell(t, 0, 1, "RSI14", text_color=color.gray)
table.cell(t, 1, 1, str.tostring(rsi14, "#.0"), text_color=color.white)
table.cell(t, 0, 2, "AB4 Gate", text_color=color.gray)
table.cell(t, 1, 2, ab4_entry ? "OPEN" : "CLOSED", text_color=ab4_entry ? color.green : color.red)
