// SRI AB1-2 Top Formation - MSTR
// Dedicated MSTR-specific bearish-theta utility indicator for MSTR.
// Green T  = keep conservative theta-centric short calls active; price likely capped
// Yellow T = upgraded AB1 bearish income opportunity with room left to monetize
// Red T    = strongest bearish-theta posture this indicator should authorize
// B        = local bearish move exhaustion; consider close/reduce short calls
// © RizenShine — framework by CIO

//@version=6
indicator(title="SRI AB1-2 Top Formation - MSTR", shorttitle="AB1-2 MSTR", overlay=true, max_labels_count=200)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
string grp_core = "Core Settings"
int at_period   = input.int(14, "Trackline ATR Period", group=grp_core)
float at_coeff  = input.float(1.0, "Trackline ATR Coefficient", group=grp_core)
float support_gap_trigger = input.float(4.0, "Support vacuum gap %", step=0.1, group=grp_core)
int roc_lookback = input.int(10, "ROC lookback bars", minval=2, group=grp_core)

string grp_disp = "Display"
bool show_table = input.bool(true, "Show Status Table", group=grp_disp)
bool show_fast_trackline = input.bool(true, "Show Fast Trackline", group=grp_disp)
bool show_slow_trackline = input.bool(false, "Show Slow Trackline", group=grp_disp)
bool show_green_t = input.bool(true, "Show Green T", group=grp_disp)
bool show_yellow_t = input.bool(true, "Show Yellow T", group=grp_disp)
bool show_red_t = input.bool(true, "Show Red T", group=grp_disp)
bool show_b_exhaust = input.bool(true, "Show B Exhaustion", group=grp_disp)

// ═══════════════════════════════════════════════════════════════
// TRACKLINES + SRIBI
// ═══════════════════════════════════════════════════════════════
f_trackline(int period, float coeff) =>
    atr = ta.rma(ta.tr(true), period)
    upT = low - atr * coeff
    dnT = high + atr * coeff
    cond = ta.rsi(close, period) >= 50
    var float track = 0.0
    track := cond ? math.max(upT, nz(track[1])) : math.min(dnT, nz(track[1]))
    track

float vst_ftl   = request.security(syminfo.tickerid, "120", f_trackline(at_period, at_coeff))
float vst_stl   = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float vst_sribi = vst_stl != 0 ? (vst_ftl - vst_stl) / vst_stl * 100 : 0

float st_ftl    = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float st_stl    = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float st_sribi  = st_stl != 0 ? (st_ftl - st_stl) / st_stl * 100 : 0

float lt_ftl    = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float lt_stl    = request.security(syminfo.tickerid, "W",   f_trackline(at_period, at_coeff))
float lt_sribi  = lt_stl != 0 ? (lt_ftl - lt_stl) / lt_stl * 100 : 0

float vlt_ftl   = request.security(syminfo.tickerid, "480", f_trackline(at_period, at_coeff))
float vlt_stl   = request.security(syminfo.tickerid, "2W",  f_trackline(at_period, at_coeff))
float vlt_sribi = vlt_stl != 0 ? (vlt_ftl - vlt_stl) / vlt_stl * 100 : 0

float sribi_avg = (vst_sribi + st_sribi + lt_sribi + vlt_sribi) / 4.0
float hist = sribi_avg

// LOI-style structural weakness proxy (mirrors existing weighted framework idea)
float vlt_norm = math.max(-100, math.min(100, vlt_sribi * 2.5))
float roc_norm = math.max(-100, math.min(100, (vlt_sribi - nz(vlt_sribi[10])) * 5.0))
float lt_norm  = math.max(-100, math.min(100, lt_sribi * 2.5))
float conc_raw = (vlt_sribi + lt_sribi) / 2.0
float conc_norm = math.max(-100, math.min(100, conc_raw * 2.5))
float loi = (vlt_norm * 40 + roc_norm * 30 + lt_norm * 15 + conc_norm * 15) / 100

// ═══════════════════════════════════════════════════════════════
// TOPPING BUCKETS
// ═══════════════════════════════════════════════════════════════
// A — rejection / exhaustion
bool bucket_reject = close < lt_ftl and high >= lt_ftl
bool bucket_failed_reclaim = close < st_ftl and high > st_ftl and close < open

// B — deterioration / compression collapse
bool bucket_band_deterioration = st_sribi < nz(st_sribi[1]) and vst_sribi < nz(vst_sribi[1])
bool bucket_lt_deterioration   = lt_sribi < nz(lt_sribi[1])

// C — structure break / tactical failure
bool bucket_st_break = close < st_ftl and st_ftl < nz(st_ftl[1])
bool bucket_lt_fast_resistance = close < lt_ftl and lt_ftl < nz(lt_ftl[1])
bool bucket_fastline_cap = close < st_ftl and high <= st_ftl * 1.01

// D — support vacuum / downside release
float support_gap_pct = close != 0 ? math.max(0.0, (close - vlt_ftl) / close * 100) : 0.0
bool bucket_support_vacuum = close > vlt_ftl and support_gap_pct > support_gap_trigger

// E — FF ROC tactical deterioration proxy
float vlt_roc = vlt_sribi - nz(vlt_sribi[roc_lookback])
float prev_vlt_roc = nz(vlt_roc[1])
bool bucket_roc_deterioration = vlt_roc < prev_vlt_roc and st_sribi < nz(st_sribi[1])

// ═══════════════════════════════════════════════════════════════
// SCORE + PHASE + VIABILITY
// ═══════════════════════════════════════════════════════════════
int green_score = 0
if bucket_fastline_cap
    green_score += 2
if bucket_band_deterioration
    green_score += 1
if bucket_reject
    green_score += 1
if bucket_roc_deterioration
    green_score += 1

int yellow_score = 0
if bucket_reject
    yellow_score += 1
if bucket_failed_reclaim
    yellow_score += 1
if bucket_band_deterioration
    yellow_score += 1
if bucket_st_break
    yellow_score += 2
if bucket_lt_fast_resistance
    yellow_score += 1
if bucket_roc_deterioration
    yellow_score += 2
if bucket_support_vacuum
    yellow_score += 1

int red_score = 0
if bucket_st_break
    red_score += 1
if bucket_lt_fast_resistance
    red_score += 1
if bucket_lt_deterioration
    red_score += 1
if bucket_support_vacuum
    red_score += 2
if bucket_roc_deterioration
    red_score += 2
if bucket_failed_reclaim
    red_score += 1

bool theta_regime = green_score >= 3

float recent_drop_pct = close != 0 ? math.max(0.0, (ta.highest(high, 5) - close) / close * 100) : 0.0
float dist_below_ftl_pct = close != 0 ? math.max(0.0, (st_ftl - close) / close * 100) : 0.0
bool histogram_turn_down = hist < nz(hist[1]) and nz(hist[1]) < nz(hist[2])
bool downside_extension_not_extreme = recent_drop_pct < 9.0 and dist_below_ftl_pct < 6.0
bool climactic_flush = ((open - close) / close * 100 > 4.5) and ((high - low) / close * 100 > 6.0)
bool not_too_late = downside_extension_not_extreme and not climactic_flush

bool early_failed_reclaim = close < st_ftl and high >= st_ftl and close <= open
bool early_break_pressure = close < st_ftl and close < nz(close[1]) and st_ftl <= nz(st_ftl[1])
bool early_rollover = bucket_roc_deterioration or histogram_turn_down
bool early_not_extended = recent_drop_pct < 6.5 and dist_below_ftl_pct < 4.0
bool ab1_state = theta_regime and (early_failed_reclaim or early_break_pressure) and early_rollover and early_not_extended

bool stronger_bearish_pressure = bucket_support_vacuum or bucket_lt_deterioration or bucket_lt_fast_resistance
bool red_not_exhausted = recent_drop_pct < 9.5 and dist_below_ftl_pct < 6.0
bool ab2_state = ab1_state and stronger_bearish_pressure and red_not_exhausted and red_score >= 2

bool exhaustion_extension = recent_drop_pct > 6.5 or dist_below_ftl_pct > 4.5
bool downside_decelerating = hist > nz(hist[1]) or vlt_roc > nz(vlt_roc[1]) or close > nz(close[1])
bool flush_reversal_bar = ((close - low) / math.max(high - low, syminfo.mintick)) > 0.55 and close >= open
bool b_exhaust_state = theta_regime and exhaustion_extension and downside_decelerating and (flush_reversal_bar or close > nz(close[1]) or yellow_score >= 4)

int top_score = ab2_state ? red_score : ab1_state ? yellow_score : theta_regime ? green_score : 0
string phase = ab2_state ? "RED" : ab1_state ? "YELLOW" : theta_regime ? "GREEN" : "-"
string status = ab2_state ? "Maximum bearish theta posture" : ab1_state ? "AB1 bearish income opportunity" : theta_regime ? "Theta-active cap regime" : "Inactive"
string conviction = ab2_state ? "Press harder" : ab1_state ? "Entry viable" : theta_regime ? "Keep active" : "No"
string ab1_viable = ab1_state ? "Entry viable" : theta_regime ? "Keep active" : "No"
string ab2_viable = ab2_state ? "External context" : ab1_state ? "Use stage / TLs" : "No"
string delta_posture = ab2_state ? "Aggressive theta posture" : ab1_state ? "Moderate (~30Δ or lower)" : theta_regime ? "Conservative (~20Δ or lower)" : "None"
string invalidation = b_exhaust_state ? "Consider close/reduce short calls" : ab2_state or ab1_state ? str.format("Close > ST FTL {0}", str.tostring(st_ftl, "#.##")) : str.format("Reclaim ST FTL {0}", str.tostring(st_ftl, "#.##"))

bool green_t = theta_regime and not (bar_index > 0 and theta_regime[1])
bool yellow_t = ab1_state and not (bar_index > 0 and ab1_state[1])
bool red_t = ab2_state and not (bar_index > 0 and ab2_state[1])
bool b_exhaust = b_exhaust_state and not (bar_index > 0 and b_exhaust_state[1])

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════
color fast_col = st_ftl > nz(st_ftl[1]) ? color.new(color.teal, 20) : color.new(color.maroon, 20)
color slow_col = lt_ftl > nz(lt_ftl[1]) ? color.new(color.teal, 45) : color.new(color.maroon, 45)
plot(show_fast_trackline ? st_ftl : na, "Fast Trackline", color=fast_col, linewidth=2, style=plot.style_circles)
plot(show_slow_trackline ? lt_ftl : na, "Slow Trackline", color=slow_col, linewidth=2)

plotshape(show_green_t and green_t, title="Green T", text="T", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
plotshape(show_yellow_t and yellow_t, title="Yellow T", text="T", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.yellow, 0), textcolor=color.black, size=size.small)
plotshape(show_red_t and red_t, title="Red T", text="T", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.red, 0), textcolor=color.white, size=size.small)
plotshape(show_b_exhaust and b_exhaust, title="B Exhaust", text="B", style=shape.labelup, location=location.belowbar,
     color=color.new(color.aqua, 0), textcolor=color.black, size=size.small)

// Explicit numeric export series for CSV/backtesting fidelity
plot(green_t ? 1 : 0, title="Green T Export", display=display.none)
plot(yellow_t ? 1 : 0, title="Yellow T Export", display=display.none)
plot(red_t ? 1 : 0, title="Red T Export", display=display.none)
plot(b_exhaust ? 1 : 0, title="B Exhaust Export", display=display.none)

// ═══════════════════════════════════════════════════════════════
// TABLE
// ═══════════════════════════════════════════════════════════════
var table t = table.new(position.bottom_right, 2, 7,
    bgcolor=color.new(color.black, 30), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast and show_table
    color hdr_bg = top_score >= 7 ? color.new(color.red, 35) : top_score >= 5 ? color.new(color.orange, 35) : top_score >= 3 ? color.new(color.green, 35) : color.new(color.gray, 40)
    color val_clr = top_score >= 7 ? color.red : top_score >= 5 ? color.orange : top_score >= 3 ? color.green : color.gray
    table.cell(t, 0, 0, "AB1-2 MSTR", text_color=color.white, text_size=size.small, bgcolor=hdr_bg)
    table.cell(t, 1, 0, status, text_color=color.white, text_size=size.small, bgcolor=hdr_bg)
    table.cell(t, 0, 1, "Status", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, phase, text_color=val_clr, text_size=size.tiny)
    table.cell(t, 0, 2, "Utility", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, str.format("{0} ({1})", conviction, str.tostring(top_score)), text_color=val_clr, text_size=size.tiny)
    table.cell(t, 0, 3, "AB1", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, ab1_viable, text_color=ab1_viable == "Entry viable" ? color.yellow : ab1_viable == "Keep active" ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 4, "AB2", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, ab2_viable, text_color=ab2_viable == "Entry viable" ? color.red : ab2_viable == "Developing" ? color.orange : color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "Delta", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, delta_posture, text_color=ab2_state ? color.red : ab1_state ? color.yellow : theta_regime ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 6, "Invalidation", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 6, invalidation, text_color=color.gray, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════
alertcondition(green_t, title="AB1-2 MSTR — Green T", message="AB1-2 MSTR: conservative bearish theta regime active. Keep short calls active (Green T).")
alertcondition(yellow_t, title="AB1-2 MSTR — Yellow T", message="AB1-2 MSTR: upgraded AB1 bearish income opportunity with room left to monetize (Yellow T).")
alertcondition(red_t, title="AB1-2 MSTR — Red T", message="AB1-2 MSTR: strongest bearish theta posture this indicator should authorize (Red T).")
alertcondition(b_exhaust, title="AB1-2 MSTR — B Exhaust", message="AB1-2 MSTR: local bearish move likely exhausted; consider closing or reducing short calls (B).")
