// MTF SMA — Multi-Timeframe Simple Moving Average
// Allows selection of any supported timeframe for the SMA calculation while plotting on the current chart.
// Designed for use cases such as 200-week SMA on daily candles, 50-day SMA on 4H, etc.
// Supports the same timeframe toggle pattern used in the RSI and Stoch RSI indicators.
// © RizenShine — Multi-timeframe utility layer for CIO SRI engine

//@version=6
indicator("MTF SMA", shorttitle="MTF SMA", overlay=true, max_bars_back=2000)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_sma = "SMA Settings"
i_length = input.int(200, "SMA Length", minval=1, maxval=1000, group=grp_sma)
i_src    = input.source(close, "Source", group=grp_sma)

grp_tf = "Timeframe"
i_tf = input.string("W", "Timeframe", 
     options=["Auto (Current)", "1", "3", "5", "15", "30", "45", "60", "120", "180", "240", "D", "W", "M"], 
     group=grp_tf)

// ═══════════════════════════════════════════════════════════════
// TIMEFRAME RESOLUTION
// ═══════════════════════════════════════════════════════════════
tf = i_tf == "Auto (Current)" ? timeframe.period : i_tf

// ═══════════════════════════════════════════════════════════════
// MTF SMA CALCULATION
// ═══════════════════════════════════════════════════════════════
sma_mtf = request.security(syminfo.tickerid, tf, ta.sma(i_src, i_length))

// ═══════════════════════════════════════════════════════════════
// PLOT
// ═══════════════════════════════════════════════════════════════
plot(sma_mtf, "MTF SMA", color=color.new(color.orange, 0), linewidth=2)

// Optional: show when price is above/below the MTF SMA
bull = close > sma_mtf
bear = close < sma_mtf

bgcolor(bull ? color.new(color.green, 92) : na)
bgcolor(bear ? color.new(color.red, 92) : na)
