//@version=5
indicator("SRI Calibrated Groups v3.2.2", shorttitle="SRI-CG", overlay=true, 
     timeframe="", timeframe_gaps=true, max_bars_back=2000)

// ─────────────────────────────────────────────────────────────────────────────
// CALIBRATED GROUPS — AUTO-DETECTION
// ─────────────────────────────────────────────────────────────────────────────
ticker = syminfo.ticker

var string group = "DEFAULT"

if ticker == "MSTR" or ticker == "TSLA"
    group := "HIGH_BETA"
else if (ticker == "IBIT" or ticker == "BTCUSD" or ticker == "BTCUSDT")
    group := "BTC_PROXY"
else if (ticker == "SPY" or ticker == "QQQ" or ticker == "IWM")
    group := "BROAD_MARKET"
else if (ticker == "XLK" or ticker == "XLY" or ticker == "XLF")
    group := "SECTOR"
else if (ticker == "TLT" or ticker == "HYG" or ticker == "LQD")
    group := "FIXED_INCOME"
else if (ticker == "VIX" or ticker == "DXY")
    group := "MACRO"
else
    group := "DEFAULT"

// ─────────────────────────────────────────────────────────────────────────────
// GROUP-SPECIFIC CALIBRATED PARAMETERS
// ─────────────────────────────────────────────────────────────────────────────
float base_loi_threshold   = na
float momentum_mult        = na
float vol_adj              = na
float stage3_discount      = na

if group == "HIGH_BETA"
    base_loi_threshold := -45.0
    momentum_mult      := 1.15
    vol_adj            := 1.08
    stage3_discount    := 0.92
else if group == "BTC_PROXY"
    base_loi_threshold := -42.0
    momentum_mult      := 1.10
    vol_adj            := 1.05
    stage3_discount    := 1.00
else if group == "BROAD_MARKET"
    base_loi_threshold := -38.0
    momentum_mult      := 1.00
    vol_adj            := 0.95
    stage3_discount    := 1.00
else if group == "SECTOR"
    base_loi_threshold := -40.0
    momentum_mult      := 1.05
    vol_adj            := 1.00
    stage3_discount    := 1.00
else if group == "FIXED_INCOME"
    base_loi_threshold := -35.0
    momentum_mult      := 0.90
    vol_adj            := 0.85
    stage3_discount    := 1.00
else
    base_loi_threshold := -40.0
    momentum_mult      := 1.00
    vol_adj            := 1.00
    stage3_discount    := 1.00

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS (only runtime-safe toggles — threshold is now fully group-driven)
// ─────────────────────────────────────────────────────────────────────────────
use_adaptive = input.bool(true, "Use Adaptive LOI (Vol-adjusted)")
apply_saylor = input.bool(true, "Apply Saylor Event Discount (Stage 3)")

// ─────────────────────────────────────────────────────────────────────────────
// CORE CALCULATION
// ─────────────────────────────────────────────────────────────────────────────
float raw_loi = ta.rsi(close, 14) - 50

float adaptive_loi = use_adaptive ? raw_loi * vol_adj : raw_loi
float final_loi    = adaptive_loi * momentum_mult

float effective_loi = (group == "HIGH_BETA" and apply_saylor) ? final_loi * stage3_discount : final_loi

bool bullish_signal = effective_loi > base_loi_threshold
bool bearish_signal = effective_loi < base_loi_threshold * 0.6

// ─────────────────────────────────────────────────────────────────────────────
// VISUALS — plot() does not support style_dashed; use plain plot for threshold
// ─────────────────────────────────────────────────────────────────────────────
plot(effective_loi, "Effective LOI", color=color.new(color.orange, 0), linewidth=2)

// Threshold as solid line (dashed style not available on plot() in v5)
plot(base_loi_threshold, "LOI Threshold", color=color.gray, linewidth=1)

bgcolor(bullish_signal ? color.new(color.green, 85) : na)
bgcolor(bearish_signal ? color.new(color.red, 85) : na)

var table info = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 70))
table.cell(info, 0, 0, "Ticker", text_color=color.gray)
table.cell(info, 1, 0, ticker, text_color=color.white)
table.cell(info, 0, 1, "Group", text_color=color.gray)
table.cell(info, 1, 1, group, text_color=color.aqua)
table.cell(info, 0, 2, "LOI Thresh", text_color=color.gray)
table.cell(info, 1, 2, str.tostring(base_loi_threshold, "#.00"), text_color=color.white)
table.cell(info, 0, 3, "Effective LOI", text_color=color.gray)
table.cell(info, 1, 3, str.tostring(effective_loi, "#.00"), text_color=color.orange)

alertcondition(bullish_signal and not bullish_signal[1], "Bullish LOI Cross", "LOI crossed above calibrated threshold")
alertcondition(bearish_signal and not bearish_signal[1], "Bearish LOI Cross", "LOI crossed below calibrated threshold")
