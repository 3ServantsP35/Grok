// SRI Forecast AB2 — Credit Spread Conditions (v4)
// P6/Engine Framework:
//   Gate: MIXED context ONLY (LT<0, VLT>0). Validated across all eligible assets.
//   Strategy: Bull Put Spread (sell puts into ST+ divergence).
//   Exit: LT turns positive (structural catch-up complete = 90-bar max).
//   IBIT disabled (MIXED ctx doesn't predict reliable LT catch-up on crypto-adjacent).
//   Bear Call + Iron Condor disabled pending P14 (Bearish Bias Indicator Suite).
//
// Visual: Background shows MIXED opportunity clearly.
//   Green   = MIXED + ST+ = window open — favorable for Bull Put
//   Yellow  = ST+ but not MIXED (sub-optimal — note context)
//   Orange  = MIXED but ST not yet + (wait for ST)
//   Red/dim = TAILWIND (LT already +, spread window closed) or HEADWIND (avoid)
//
// Alerts: Confirmation ladder only (MIXED entry cross, LT exit cross).
// © RizenShine — Forecast engine by CIO

//@version=6
indicator(title="SRI Forecast AB2", shorttitle="SRI AB2", overlay=true, max_lines_count=500, max_labels_count=50)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

string grp_mode = "Asset Classification"
string asset_class = input.string("Auto-Detect", "Asset Class",
    options=["Auto-Detect", "BTC-Proxy (MSTR/IBIT)", "Business Momentum (TSLA)", "Trending (GLD)", "MR-Large (SPY/QQQ)", "MR-Small (IWM)"],
    group=grp_mode)

string grp_core = "Core Settings"
int at_period   = input.int(14, "Trackline ATR Period", group=grp_core)
float at_coeff  = input.float(1.0, "Trackline ATR Coefficient", group=grp_core)

string grp_disp = "Display"
bool show_table   = input.bool(true,  "Show Info Table",          group=grp_disp)
bool show_legend  = input.bool(true,  "Show Legend",              group=grp_disp)
bool show_bg      = input.bool(true,  "Show Context Background",  group=grp_disp)
bool show_ribbon  = input.bool(false, "Show Forecast Ribbon",     group=grp_disp)
bool show_tracklines = input.bool(true, "Show LT Tracklines",     group=grp_disp)

// ═══════════════════════════════════════════════════════════════
// ASSET CLASS AUTO-DETECT
// ═══════════════════════════════════════════════════════════════

f_is_ibit() =>
    string t = str.upper(syminfo.ticker)
    str.contains(t, "IBIT") or str.contains(t, "GBTC") or str.contains(t, "BITO")

f_is_btc_proxy() =>
    string t = str.upper(syminfo.ticker)
    (syminfo.type == "crypto" or str.contains(t, "BTC") or str.contains(t, "MSTR") or
     str.contains(t, "IBIT") or str.contains(t, "GBTC") or str.contains(t, "BITO") or str.contains(t, "PURR"))

f_is_tsla() =>
    str.upper(syminfo.ticker) == "TSLA"

f_is_gld() =>
    string t = str.upper(syminfo.ticker)
    str.contains(t, "GLD") or str.contains(t, "IAU") or str.contains(t, "XAUUSD")

f_is_iwm() =>
    string t = str.upper(syminfo.ticker)
    str.contains(t, "IWM") or str.contains(t, "RUT") or str.contains(t, "TNA")

string auto_class = f_is_tsla() ? "Business Momentum (TSLA)" :
     f_is_btc_proxy() ? "BTC-Proxy (MSTR/IBIT)" :
     f_is_gld() ? "Trending (GLD)" :
     f_is_iwm() ? "MR-Small (IWM)" : "MR-Large (SPY/QQQ)"

string resolved_class = asset_class == "Auto-Detect" ? auto_class : asset_class

bool is_btc_proxy = resolved_class == "BTC-Proxy (MSTR/IBIT)"
bool is_ibit      = f_is_ibit()  // Flag IBIT specifically — disabled for AB2
bool is_mr        = resolved_class == "MR-Large (SPY/QQQ)" or resolved_class == "MR-Small (IWM)"
bool is_momentum  = is_btc_proxy or resolved_class == "Business Momentum (TSLA)"

// ═══════════════════════════════════════════════════════════════
// TRACKLINES + SRIBI
// ═══════════════════════════════════════════════════════════════

f_trackline(int period, float coeff) =>
    atr = ta.rma(ta.tr(true), period)
    upT   = low  - atr * coeff
    downT = high + atr * coeff
    cond  = ta.rsi(close, period) >= 50
    var float track = 0.0
    track := cond ? math.max(upT, nz(track[1])) : math.min(downT, nz(track[1]))
    track

float vst_ftl  = request.security(syminfo.tickerid, "120", f_trackline(at_period, at_coeff))
float vst_stl  = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float vst_sribi = vst_stl != 0 ? (vst_ftl - vst_stl) / vst_stl * 100 : 0

float st_ftl   = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float st_stl   = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float st_sribi  = st_stl != 0 ? (st_ftl - st_stl) / st_stl * 100 : 0

float lt_ftl   = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float lt_stl   = request.security(syminfo.tickerid, "W",   f_trackline(at_period, at_coeff))
float lt_sribi  = lt_stl != 0 ? (lt_ftl - lt_stl) / lt_stl * 100 : 0

float vlt_ftl  = request.security(syminfo.tickerid, "480", f_trackline(at_period, at_coeff))
float vlt_stl  = request.security(syminfo.tickerid, "2W",  f_trackline(at_period, at_coeff))
float vlt_sribi = vlt_stl != 0 ? (vlt_ftl - vlt_stl) / vlt_stl * 100 : 0

int bull_count  = (vst_sribi > 0 ? 1 : 0) + (st_sribi > 0 ? 1 : 0) + (lt_sribi > 0 ? 1 : 0) + (vlt_sribi > 0 ? 1 : 0)
float sribi_avg = (vst_sribi + st_sribi + lt_sribi + vlt_sribi) / 4.0

// ═══════════════════════════════════════════════════════════════
// CONTEXT CLASSIFICATION
// ═══════════════════════════════════════════════════════════════

bool lt_neg  = lt_sribi < 0
bool lt_pos  = lt_sribi > 0
bool vlt_pos = vlt_sribi > 0
bool vlt_neg = vlt_sribi < 0
bool st_pos  = st_sribi > 0
bool vst_pos = vst_sribi > 0

string context = lt_neg and vlt_neg ? "HEADWIND" : lt_pos and vlt_pos ? "TAILWIND" : "MIXED"

bool is_mixed    = context == "MIXED"
bool is_tailwind = context == "TAILWIND"
bool is_headwind = context == "HEADWIND"

// ═══════════════════════════════════════════════════════════════
// ST CROSSES (decision layer)
// ═══════════════════════════════════════════════════════════════

bool st_cross_bull = st_pos and nz(st_sribi[1]) <= 0
bool st_cross_bear = st_sribi < 0 and nz(st_sribi[1]) >= 0

// ═══════════════════════════════════════════════════════════════
// AB2 CONDITION: MIXED + ST+
// Primary: Bull Put window (MIXED context confirmed)
// The MIXED context is what gives the structural tension that resolves upward.
// TAILWIND = LT already positive = spread window CLOSED (too late to enter).
// HEADWIND = both LT and VLT negative = avoid (no catalyst for resolution).
// ═══════════════════════════════════════════════════════════════

// Spread window open: MIXED context with ST+ and VST confirming
bool window_open    = is_mixed and st_pos and vst_pos
bool window_crossed = is_mixed and st_cross_bull and vst_pos

// Context crossing into MIXED (regardless of ST — useful for alert)
bool mixed_entry    = is_mixed and context[1] != "MIXED"

// LT turning positive = spread exit signal
bool lt_positive_cross = lt_pos and nz(lt_sribi[1]) <= 0  // close the spread

// Time stop reference (90 bars max per engine rule)
// Track bars in MIXED context since ST turned positive
var int mixed_bar_enter = -999
if window_crossed
    mixed_bar_enter := bar_index
int bars_in_window = window_open and mixed_bar_enter > 0 ? bar_index - mixed_bar_enter : 0
bool time_stop_warn = bars_in_window >= 80  // warn at 80, hard stop at 90
bool time_stop_hit  = bars_in_window >= 90

// IBIT override — window shows but flagged disabled
bool ibit_override = is_ibit

// ═══════════════════════════════════════════════════════════════
// CONDITION COLORS
// Green  = window open (MIXED + ST+ + VST+) — favorable for Bull Put
// Orange = MIXED but ST not yet + — wait for ST cross
// Yellow = ST+ but context is not MIXED (TAILWIND or HEADWIND with ST recovery)
// Red    = TAILWIND (window closed — LT caught up) or HEADWIND (avoid)
// Gray   = no clear signal
// ═══════════════════════════════════════════════════════════════

color bg_col = ibit_override     ? color.new(color.purple, 92) :
     window_open    ? color.new(color.green,  87) :
     is_mixed and not st_pos ? color.new(color.orange, 90) :
     is_tailwind    ? color.new(color.red, 94)    :
     is_headwind    ? color.new(color.gray, 97)   : na

bgcolor(show_bg ? bg_col : na)

// ═══════════════════════════════════════════════════════════════
// LT BACKBONE (structural reference)
// Color shows whether price is above/below LT slow trackline
// ═══════════════════════════════════════════════════════════════

bool lt_bullish      = lt_ftl > lt_stl
bool lt_ftl_rising   = lt_ftl > nz(lt_ftl[1])

color ftl_col = lt_ftl_rising ? color.new(color.teal, 35) : color.new(color.maroon, 35)
color stl_col = is_mixed  ? color.new(color.yellow, 0)  :
     lt_bullish ? color.new(color.teal, 30) : color.new(color.maroon, 30)

plot(show_tracklines ? lt_ftl : na, "LT Fast TL", color=ftl_col, linewidth=2, style=plot.style_circles)
plot(show_tracklines ? lt_stl : na, "LT Slow TL", color=stl_col, linewidth=3)

// ═══════════════════════════════════════════════════════════════
// ENTRY / EXIT MARKERS (minimal — on crossing only)
// ═══════════════════════════════════════════════════════════════

plotshape(window_crossed and not ibit_override, title="BP Entry", location=location.belowbar,
    style=shape.diamond, color=color.new(#39FF14, 0), size=size.small)
plotshape(mixed_entry and not st_pos and not ibit_override, title="MIXED Watch", location=location.belowbar,
    style=shape.circle, color=color.orange, size=size.tiny)
plotshape(lt_positive_cross, title="LT Exit",   location=location.abovebar,
    style=shape.xcross, color=color.new(color.blue, 20), size=size.small)
plotshape(time_stop_hit, title="Time Stop",     location=location.abovebar,
    style=shape.xcross, color=color.new(color.orange, 20), size=size.tiny)
plotshape(ibit_override, title="IBIT Disabled", location=location.belowbar,
    style=shape.circle, color=color.new(color.purple, 40), size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// FORECAST RIBBON (optional — from backtested SRIBI-zone returns)
// ═══════════════════════════════════════════════════════════════

int zone = sribi_avg < -25 ? 1 : sribi_avg < -5 ? 2 : sribi_avg < 5 ? 3 : sribi_avg < 25 ? 4 : 5
color zone_color  = zone == 1 ? color.new(color.red, 0) : zone == 2 ? color.new(color.orange, 0) :
     zone == 3 ? color.new(color.gray, 0) : zone == 4 ? color.new(color.teal, 0) : color.new(color.green, 0)
color ribbon_fill = zone == 1 ? color.new(color.red, 80) : zone == 2 ? color.new(color.orange, 80) :
     zone == 3 ? color.new(color.gray, 85) : zone == 4 ? color.new(color.teal, 80) : color.new(color.green, 80)

f_get_pct(int z, int di, int p) =>
    float r = 0.0
    if z == 1
        r := p == 0 ? (di==0?-2.91:di==1?-3.66:di==2?-4.92:-5.81) : p==1 ? (di==0?0.81:di==1?0.43:di==2?0.70:1.29) : (di==0?4.21:di==1?5.72:di==2?6.93:8.74)
    else if z == 2
        r := p == 0 ? (di==0?-3.30:di==1?-4.80:di==2?-5.83:-8.28) : p==1 ? (di==0?-0.24:di==1?-0.30:di==2?-0.15:-0.58) : (di==0?2.72:di==1?4.41:di==2?5.18:6.71)
    else if z == 3
        r := p == 0 ? (di==0?-3.00:di==1?-4.95:di==2?-5.81:-6.19) : p==1 ? (di==0?-0.15:di==1?-0.12:di==2?-1.03:-1.21) : (di==0?3.21:di==1?4.46:di==2?5.36:6.77)
    else if z == 4
        r := p == 0 ? (di==0?-2.67:di==1?-4.07:di==2?-4.61:-5.86) : p==1 ? (di==0?0.29:di==1?0.85:di==2?0.86:0.10)    : (di==0?3.72:di==1?6.10:di==2?7.19:8.95)
    else
        r := p == 0 ? (di==0?-2.76:di==1?-4.45:di==2?-4.79:-4.61) : p==1 ? (di==0?0.08:di==1?1.01:di==2?1.42:2.78)    : (di==0?3.73:di==1?6.19:di==2?8.98:10.96)
    r

if barstate.islast and show_ribbon
    float bp = close
    int[] offs = array.from(0, 5, 10, 15, 20)
    var line[] blines = array.new<line>()
    var line[] mlines = array.new<line>()
    var line[] slines = array.new<line>()
    var linefill[] fills = array.new<linefill>()
    if array.size(blines)>0
        for i=0 to array.size(blines)-1
            line.delete(array.get(blines,i))
        array.clear(blines)
    if array.size(mlines)>0
        for i=0 to array.size(mlines)-1
            line.delete(array.get(mlines,i))
        array.clear(mlines)
    if array.size(slines)>0
        for i=0 to array.size(slines)-1
            line.delete(array.get(slines,i))
        array.clear(slines)
    if array.size(fills)>0
        for i=0 to array.size(fills)-1
            linefill.delete(array.get(fills,i))
        array.clear(fills)
    for seg=0 to 3
        int bs = bar_index + array.get(offs, seg)
        int be = bar_index + array.get(offs, seg+1)
        float p25s = seg==0 ? 0.0 : f_get_pct(zone, seg-1, 0)
        float p50s = seg==0 ? 0.0 : f_get_pct(zone, seg-1, 1)
        float p75s = seg==0 ? 0.0 : f_get_pct(zone, seg-1, 2)
        float p25e = f_get_pct(zone, seg, 0)
        float p50e = f_get_pct(zone, seg, 1)
        float p75e = f_get_pct(zone, seg, 2)
        line bl = line.new(bs, bp*(1+p75s/100), be, bp*(1+p75e/100), color=color.new(zone_color,50), width=1, style=line.style_dashed)
        line ml = line.new(bs, bp*(1+p50s/100), be, bp*(1+p50e/100), color=zone_color, width=2)
        line sl = line.new(bs, bp*(1+p25s/100), be, bp*(1+p25e/100), color=color.new(zone_color,50), width=1, style=line.style_dashed)
        array.push(blines, bl)
        array.push(mlines, ml)
        array.push(slines, sl)
        array.push(fills, linefill.new(bl, sl, ribbon_fill))

// ═══════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════

var table t = table.new(position.bottom_right, 2, 13,
    bgcolor=color.new(color.black, 30), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast and show_table
    string class_short = is_ibit ? "IBIT ⛔" : is_btc_proxy ? "BTC-Proxy" :
         resolved_class == "Business Momentum (TSLA)" ? "TSLA" :
         resolved_class == "Trending (GLD)" ? "GLD" :
         resolved_class == "MR-Small (IWM)" ? "IWM" : "MR"

    color hdr_bg = ibit_override ? color.new(color.purple, 40) :
         window_open ? color.new(color.green, 30) :
         is_mixed and not st_pos ? color.new(color.orange, 40) :
         is_tailwind ? color.new(color.red, 40) : color.new(color.gray, 40)

    string hdr_str = ibit_override ? "DISABLED (crypto)" :
         window_open ? "WINDOW OPEN" :
         is_mixed and not st_pos ? "MIXED — WAIT ST" :
         is_tailwind ? "LT+ — WINDOW CLOSED" : "HEADWIND — AVOID"

    table.cell(t, 0, 0, str.format("AB2 Bull Put [{0}]", class_short), text_color=color.white, text_size=size.small, bgcolor=hdr_bg)
    table.cell(t, 1, 0, hdr_str, text_color=color.white, text_size=size.small, bgcolor=hdr_bg)

    color ctx_clr = is_mixed ? color.yellow : is_tailwind ? color.green : color.red
    table.cell(t, 0, 1, "Context", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, context, text_color=ctx_clr, text_size=size.tiny)

    table.cell(t, 0, 2, "ST  (Decision)", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, str.format("{0} {1}", st_pos?"●":"○", str.tostring(st_sribi,"#.#")),
        text_color=st_pos?color.teal:color.red, text_size=size.tiny)
    table.cell(t, 0, 3, "VST (Timing)",   text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, str.format("{0} {1}", vst_pos?"●":"○", str.tostring(vst_sribi,"#.#")),
        text_color=vst_pos?color.teal:color.red, text_size=size.tiny)
    table.cell(t, 0, 4, "LT  (Exit Gate)", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, str.format("{0} {1} {2}", lt_pos?"▲":"▼", str.tostring(lt_sribi,"#.#"), lt_positive_cross?"← EXIT":""),
        text_color=lt_pos?color.teal:color.red, text_size=size.tiny)
    table.cell(t, 0, 5, "VLT (Context)",  text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, str.format("{0} {1}", vlt_pos?"▲":"▼", str.tostring(vlt_sribi,"#.#")),
        text_color=vlt_pos?color.teal:color.red, text_size=size.tiny)

    // Window status
    string win_str = window_open ? str.format("Open — {0} bars", bars_in_window) :
         is_mixed ? "MIXED — waiting ST+" : is_tailwind ? "Closed (LT+)" : "Closed (HW)"
    color win_clr = window_open ? color.green : is_mixed ? color.orange : color.red
    table.cell(t, 0, 6, "BP Window",  text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 6, win_str, text_color=win_clr, text_size=size.tiny)

    // Time stop
    if window_open and bars_in_window > 60
        color ts_clr = time_stop_hit ? color.red : color.orange
        table.cell(t, 0, 7, "⏱ Time Stop", text_color=ts_clr, text_size=size.tiny)
        table.cell(t, 1, 7, str.format("{0}/90 bars", bars_in_window), text_color=ts_clr, text_size=size.tiny)
    else
        table.cell(t, 0, 7, "Exit Rule", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 7, "LT turns + or 90-bar stop", text_color=color.gray, text_size=size.tiny)

    // Disabled strategies note
    table.cell(t, 0, 8, "Bear Call / IC", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 8, "Disabled — pending P14", text_color=color.gray, text_size=size.tiny)

    // SRIBI zone context
    string zone_str = zone == 1 ? "Very Bearish" : zone == 2 ? "Bearish" : zone == 3 ? "Neutral" : zone == 4 ? "Bullish" : "Very Bullish"
    table.cell(t, 0, 9, "SRIBI Zone", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 9, str.format("{0} ({1})", zone_str, str.tostring(sribi_avg,"#.#")), text_color=zone_color, text_size=size.tiny)

    // IBIT disabled warning
    if ibit_override
        table.cell(t, 0, 10, "⛔ IBIT", text_color=color.purple, text_size=size.tiny)
        table.cell(t, 1, 10, "AB2 disabled — MIXED ctx unreliable on crypto-adjacent", text_color=color.purple, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// LEGEND
// ═══════════════════════════════════════════════════════════════

var table leg = table.new(position.bottom_left, 2, 9,
    bgcolor=color.new(color.black, 25), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast and show_legend
    table.cell(leg, 0, 0, "AB2 v4", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 50))
    table.cell(leg, 1, 0, "MIXED-Only", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 50))
    table.cell(leg, 0, 1, "█ Green", text_color=color.green,  text_size=size.tiny)
    table.cell(leg, 1, 1, "Window open — MIXED + ST+ + VST+", text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 2, "█ Orange", text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 2, "MIXED — waiting for ST cross", text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 3, "█ Red", text_color=color.red, text_size=size.tiny)
    table.cell(leg, 1, 3, "TAILWIND — window closed (LT+)", text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 4, "◆ green", text_color=#39FF14, text_size=size.tiny)
    table.cell(leg, 1, 4, "Bull Put entry (ST crosses in MIXED)", text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 5, "○ orange", text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 5, "Context entered MIXED — wait for ST", text_color=color.gray, text_size=size.tiny)
    table.cell(leg, 0, 6, "✕ blue", text_color=color.blue, text_size=size.tiny)
    table.cell(leg, 1, 6, "LT exit — close spread", text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 7, "✕ orange", text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 7, "90-bar time stop", text_color=color.gray, text_size=size.tiny)
    table.cell(leg, 0, 8, "○ purple", text_color=color.purple, text_size=size.tiny)
    table.cell(leg, 1, 8, "IBIT detected — AB2 disabled", text_color=color.gray, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// ALERTS — CONFIRMATION LADDER ONLY
// ═══════════════════════════════════════════════════════════════

// Step 1: Context enters MIXED (structural tension window opening)
alertcondition(mixed_entry, title="AB2 — MIXED Context Entered",
    message="AB2 Ladder: Context entered MIXED (LT<0, VLT>0). Wait for ST+ to open Bull Put window.")

// Step 2: ST crosses positive in MIXED — Bull Put window opens
alertcondition(window_crossed and not ibit_override, title="AB2 — Bull Put Window Open",
    message="AB2 Ladder: ST+ in MIXED context. Bull Put window open. VST confirming. Check strikes and PoP.")

// Step 3: LT crosses positive — close spread
alertcondition(lt_positive_cross, title="AB2 — LT Exit (Close Spread)",
    message="AB2 Ladder: LT turned positive. Structural catch-up complete — close Bull Put spread.")

// Step 4: Time stop warning
alertcondition(time_stop_warn and not time_stop_hit, title="AB2 — Time Stop Warning (80 bars)",
    message="AB2 Time Stop: 80 bars elapsed in window. Review spread — exit within 10 bars.")
alertcondition(time_stop_hit, title="AB2 — Time Stop Hit (90 bars)",
    message="AB2 Time Stop: 90-bar maximum reached. Close spread regardless of P&L.")
