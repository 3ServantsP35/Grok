//
// AB2 Call Ripeness Score (CRS)
// ─────────────────────────────────────────────────────────────────────────────
// Measures how attractive it is RIGHT NOW to sell a short call against an
// existing AB3 LEAP position (PMCC / AB2 strategy).
//
// Score 0–10 gradient:
//   0–2  → NO CALLS    (gate closed or conditions too weak)
//   3–5  → OTM ≤0.25Δ  (minimum conditions met; conservative)
//   6–8  → ATM ≤0.40Δ  (good conditions; standard AB2 income cycle)
//   9–10 → DEEP ITM    (maximum income mode; all factors aligned)
//
// THREE CORE COMPONENTS:
//   1. LOI Position     (0–4 pts) — where in the cycle; hard gate at LOI < –20
//   2. Distribution     (0–3 pts) — bearish signals forming (ideal time to sell)
//   3. IV Premium       (0–3 pts) — HV percentile proxy; is premium worth taking?
//
// HEADWIND / TAILWIND MODIFIERS (±0.5 each):
//   Howell Phase   — SPECULATION +0.5 | TURBULENCE –0.5 | CONFUSION –0.25
//   Liquidity Reg  — EXPANDING +0.5   | CONTRACTING –0.5 (auto via HYG+VIX)
//
// USAGE:
//   Add this indicator to the same chart as your AB3/LOI indicator.
//   Set "LOI Source" input to the LOI plot from your AB3 indicator.
//   Set "Howell Phase" manually from your Howell Phase Engine output.
//   Liquidity regime is auto-computed from HYG and VIX.
//
// Framework: SRI Engine v2 | AB2 PMCC Rules | Backtest: 2026-03-03
// ─────────────────────────────────────────────────────────────────────────────

//@version=5
indicator("AB2 Call Ripeness Score (CRS)", shorttitle="AB2 CRS", overlay=false, max_bars_back=500)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

var string G1 = "LOI Source"
loi_source          = input.source(close,  "LOI Plot — select from AB3 indicator", group=G1,
                       tooltip="Point this at the LOI plot in your AB3/SRI indicator on this chart. If left as 'close', the score will be invalid.")
loi_no_calls_thresh = input.float(-20.0, "LOI No-Calls Gate (hard zero below this)", group=G1,
                       tooltip="AB2 rule: no calls sold when LOI is below this level. MOMENTUM default –20.")
loi_otm_thresh      = input.float(  0.0, "LOI OTM Threshold (≥ this → OTM eligible)", group=G1)
loi_atm_thresh      = input.float( 20.0, "LOI ATM Threshold (≥ this → ATM eligible)", group=G1)
loi_deep_thresh     = input.float( 40.0, "LOI Deep ITM Threshold (DELTA_MGMT zone)",  group=G1)

var string G2 = "IV / Premium"
hv_period   = input.int(20,  "Historical Vol Period (bars)",        group=G2, minval=5,  maxval=60)
hv_lookback = input.int(252, "HV Percentile Lookback (bars)",       group=G2, minval=60, maxval=504)

var string G3 = "Headwinds & Tailwinds"
howell_phase  = input.string("TURBULENCE", "Howell Phase (manual — update from engine)",
                options=["REBOUND", "SPECULATION", "TURBULENCE", "CONFUSION"], group=G3,
                tooltip="SPECULATION = best phase for call-selling (+0.5). TURBULENCE = caution (–0.5). Update from your Howell Phase Engine Discord output.")
use_liq_auto  = input.bool(true, "Auto-detect Liquidity Regime (HYG + VIX)", group=G3,
                tooltip="Pulls HYG and VIX to classify EXPANDING / CONTRACTING / NEUTRAL. EXPANDING +0.5, CONTRACTING –0.5.")

var string G4 = "Asset"
asset_class   = input.string("MOMENTUM", "Asset Class",
                options=["MOMENTUM", "MR", "TRENDING", "BTC_CORRELATED"], group=G4,
                tooltip="MOMENTUM = MSTR/TSLA/IBIT. MR = SPY/QQQ/IWM/GLD.")
show_table    = input.bool(true, "Show Info Table", group=G4)
show_labels   = input.bool(true, "Show Crossover Labels", group=G4)

// ═══════════════════════════════════════════════════════════════════════════
// COMPONENT 1 — LOI POSITION (0–4 pts)
// Maps directly to AB2 delta gate rules.
// Hard-zero if LOI < no_calls threshold regardless of other components.
// ═══════════════════════════════════════════════════════════════════════════

float loi      = loi_source
bool  gate_open = loi >= loi_no_calls_thresh

float loi_pts = 0.0
if gate_open
    if loi >= loi_deep_thresh
        loi_pts := 4.0
    else if loi >= loi_atm_thresh
        loi_pts := 3.0
    else if loi >= loi_otm_thresh
        loi_pts := 2.0
    else
        loi_pts := 1.0

// LOI trend: rising vs falling (context, not scored — displayed in table)
float loi_slope = loi - loi[5]
string loi_dir  = loi_slope > 1.0 ? "↑" : loi_slope < -1.0 ? "↓" : "→"

// ═══════════════════════════════════════════════════════════════════════════
// COMPONENT 2 — IV PREMIUM (0–3 pts)
// HV percentile over trailing lookback window as IV proxy.
// Below 30th pctl: premium below STRC hurdle → 0 pts.
// ═══════════════════════════════════════════════════════════════════════════

float log_ret   = math.log(close / close[1])
float hv_raw    = ta.stdev(log_ret, hv_period) * math.sqrt(252) * 100
float hv_pct    = ta.percentrank(hv_raw, hv_lookback)

float iv_pts = 0.0
if hv_pct >= 70
    iv_pts := 3.0
else if hv_pct >= 50
    iv_pts := 2.0
else if hv_pct >= 30
    iv_pts := 1.0

// ═══════════════════════════════════════════════════════════════════════════
// COMPONENT 3 — DISTRIBUTION SIGNALS (0–3 pts)
// Selling calls into forming distribution = ideal AB2 setup.
// 1 pt each: MACD hist < 0 | RSI divergence | OBV below SMA20
// ═══════════════════════════════════════════════════════════════════════════

// Signal 1: MACD histogram negative
[_macd, _sig, hist] = ta.macd(close, 12, 26, 9)
bool sig_macd = hist < 0

// Signal 2: Bearish RSI divergence — price near 20-bar high, RSI not at high
float rsi14         = ta.rsi(close, 14)
bool  price_near_hi = close >= ta.highest(close, 20) * 0.98
bool  rsi_below_hi  = rsi14 < ta.highest(rsi14, 20) * 0.95
bool  sig_rsi_div   = price_near_hi and rsi_below_hi

// Signal 3: OBV below its 20-bar SMA (volume not confirming price)
float obv_val  = ta.obv
bool  sig_obv  = obv_val < ta.sma(obv_val, 20)

float dist_pts  = (sig_macd ? 1.0 : 0.0) + (sig_rsi_div ? 1.0 : 0.0) + (sig_obv ? 1.0 : 0.0)
int   dist_count = (sig_macd ? 1 : 0) + (sig_rsi_div ? 1 : 0) + (sig_obv ? 1 : 0)

// ═══════════════════════════════════════════════════════════════════════════
// HEADWIND / TAILWIND MODIFIERS
// ═══════════════════════════════════════════════════════════════════════════

// — Howell Phase modifier (manual input)
float howell_mod = switch howell_phase
    "SPECULATION" => 0.5
    "TURBULENCE"  => -0.5
    "CONFUSION"   => -0.25
    => 0.0   // REBOUND

// — Liquidity Regime modifier (auto: HYG trend + VIX level)
float liq_mod      = 0.0
string liq_regime  = "NEUTRAL"
float  liq_mod_raw = 0.0

if use_liq_auto
    float hyg_close  = request.security("AMEX:HYG",  timeframe.period, close,     lookahead=barmerge.lookahead_off)
    float hyg_sma50  = request.security("AMEX:HYG",  timeframe.period, ta.sma(close, 50), lookahead=barmerge.lookahead_off)
    float vix_close  = request.security("CBOE:VIX",  timeframe.period, close,     lookahead=barmerge.lookahead_off)

    bool hyg_bull    = not na(hyg_close) and not na(hyg_sma50) and hyg_close > hyg_sma50
    bool hyg_bear    = not na(hyg_close) and not na(hyg_sma50) and hyg_close < hyg_sma50
    bool vix_low     = not na(vix_close) and vix_close < 20
    bool vix_high    = not na(vix_close) and vix_close > 25

    if hyg_bull and vix_low
        liq_regime  := "EXPANDING"
        liq_mod_raw := 0.5
    else if hyg_bear and vix_high
        liq_regime  := "CONTRACTING"
        liq_mod_raw := -0.5
    else
        liq_regime  := "NEUTRAL"
        liq_mod_raw := 0.0

    liq_mod := liq_mod_raw

// ═══════════════════════════════════════════════════════════════════════════
// COMPOSITE CRS
// ═══════════════════════════════════════════════════════════════════════════

float base_score = gate_open ? (loi_pts + iv_pts + dist_pts) : 0.0
float modifiers  = gate_open ? (howell_mod + liq_mod)        : 0.0
float crs_raw    = base_score + modifiers
float crs        = math.max(0.0, math.min(10.0, crs_raw))

// Previous bar CRS for crossover detection
float crs_prev   = crs[1]

// ═══════════════════════════════════════════════════════════════════════════
// ACTION TIER & DISPLAY
// ═══════════════════════════════════════════════════════════════════════════

string action     = ""
string dte_label  = ""
color  bar_col    = color.gray
color  txt_col    = color.white

if not gate_open or crs < 3.0
    action    := "NO CALLS"
    dte_label := "—"
    bar_col   := color.new(color.red, 15)
    txt_col   := color.new(color.red, 0)
else if crs < 6.0
    action    := "OTM  ≤ 0.25Δ"
    dte_label := "DTE: 60–90"
    bar_col   := color.new(color.orange, 15)
    txt_col   := color.new(color.orange, 0)
else if crs < 9.0
    action    := "ATM  ≤ 0.40Δ"
    dte_label := "DTE: 45–60"
    bar_col   := color.new(color.green, 15)
    txt_col   := color.new(color.green, 0)
else
    action    := "DEEP ITM"
    dte_label := "DTE: 30–45"
    bar_col   := color.new(color.aqua, 15)
    txt_col   := color.new(color.aqua, 0)

// ═══════════════════════════════════════════════════════════════════════════
// LOI VALIDITY WARNING
// If LOI source looks like raw price (outside –100 to +100), warn the user
// ═══════════════════════════════════════════════════════════════════════════

bool loi_valid = loi >= -150 and loi <= 150
string loi_warn = loi_valid ? "" : " ⚠ SELECT LOI PLOT"

// ═══════════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════════

// Main CRS histogram
plot(loi_valid ? crs : na, "CRS",
     style=plot.style_histogram, color=bar_col, linewidth=3)

// Reference lines
hline(9, "Deep ITM",   color=color.new(color.aqua,   50), linestyle=hline.style_dashed, linewidth=1)
hline(6, "ATM Zone",   color=color.new(color.green,  50), linestyle=hline.style_dashed, linewidth=1)
hline(3, "OTM Zone",   color=color.new(color.orange, 50), linestyle=hline.style_dashed, linewidth=1)
hline(0, "No Calls",   color=color.new(color.red,    40), linestyle=hline.style_solid,  linewidth=1)

// Baseline zero line
hline(0, "", color=color.new(color.gray, 80))

// Background: green tint when calls active, red when gated
bgcolor(gate_open and crs >= 3 ? color.new(color.green, 93) : color.new(color.red, 93),
        title="Action Zone Background")

// ═══════════════════════════════════════════════════════════════════════════
// CROSSOVER LABELS  (fires once per zone transition)
// ═══════════════════════════════════════════════════════════════════════════

if show_labels and barstate.isconfirmed
    // CRS enters ATM zone (crosses 6 from below)
    if crs >= 6 and crs_prev < 6 and gate_open
        label.new(bar_index, crs + 0.3,
                  "ATM SELL\n" + str.tostring(crs, "#.#"),
                  color=color.new(color.green, 20), textcolor=color.white,
                  style=label.style_label_down, size=size.small)

    // CRS enters DEEP ITM zone
    if crs >= 9 and crs_prev < 9 and gate_open
        label.new(bar_index, crs + 0.3,
                  "DEEP ITM\n" + str.tostring(crs, "#.#"),
                  color=color.new(color.aqua, 20), textcolor=color.white,
                  style=label.style_label_down, size=size.small)

    // CRS falls below OTM zone (stop selling)
    if crs < 3 and crs_prev >= 3
        label.new(bar_index, crs - 0.3,
                  "STOP CALLS\n" + str.tostring(crs, "#.#"),
                  color=color.new(color.red, 20), textcolor=color.white,
                  style=label.style_label_up, size=size.small)

    // Gate opens (LOI crosses no-calls threshold)
    if gate_open and not gate_open[1]
        label.new(bar_index, 1.0,
                  "GATE OPEN",
                  color=color.new(color.yellow, 30), textcolor=color.black,
                  style=label.style_label_up, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// ALERT CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════

alertcondition(ta.crossover(crs,  6.0), "CRS → ATM Zone",    "AB2 CRS {{ticker}}: enters ATM call-selling zone (CRS={{plot_0}})")
alertcondition(ta.crossover(crs,  9.0), "CRS → Deep ITM",    "AB2 CRS {{ticker}}: DEEP ITM zone (CRS={{plot_0}}) — maximum income mode")
alertcondition(ta.crossunder(crs, 3.0), "CRS → No Calls",    "AB2 CRS {{ticker}}: drops below OTM floor — review open short calls")
alertcondition(ta.crossover(loi, loi_no_calls_thresh), "AB2 Gate Opens", "AB2 CRS {{ticker}}: LOI crossed no-calls gate — call selling now permitted")

// ═══════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════

if show_table and barstate.islast
    var table t = table.new(position.top_right, 2, 9,
                            bgcolor     = color.new(color.black, 75),
                            border_color= color.new(color.gray,  40),
                            border_width= 1,
                            frame_color = color.new(color.gray,  40),
                            frame_width = 1)

    // Header
    table.cell(t, 0, 0, "AB2 CRS" + loi_warn,
               text_color=color.white, text_halign=text.align_left,  text_size=size.normal)
    table.cell(t, 1, 0, str.tostring(crs, "#.0") + " / 10",
               text_color=txt_col,     text_halign=text.align_right, text_size=size.normal)

    // Action
    table.cell(t, 0, 1, "Action",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 1, action,
               text_color=txt_col, text_halign=text.align_right, text_size=size.small)

    // LOI component
    string loi_str = str.tostring(loi, "#.0") + " " + loi_dir + "  (" + str.tostring(loi_pts, "#") + "/4 pts)"
    table.cell(t, 0, 2, "LOI",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 2, loi_str,
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    // IV component
    string iv_str = "HV " + str.tostring(hv_pct, "#") + "%ile  (" + str.tostring(iv_pts, "#") + "/3 pts)"
    table.cell(t, 0, 3, "IV Premium",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 3, iv_str,
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    // Distribution signals
    string dist_sigs = (sig_macd ? "MACD " : "") + (sig_rsi_div ? "RSI " : "") + (sig_obv ? "OBV" : "")
    string dist_str  = str.tostring(dist_count) + "/3 — " + (dist_count == 0 ? "none" : dist_sigs)
    table.cell(t, 0, 4, "Distribution",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 4, dist_str,
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    // Howell modifier
    string how_str = howell_phase + "  (" + (howell_mod >= 0 ? "+" : "") + str.tostring(howell_mod, "#.##") + ")"
    table.cell(t, 0, 5, "Howell",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 5, how_str,
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    // Liquidity modifier
    string liq_str = liq_regime + "  (" + (liq_mod >= 0 ? "+" : "") + str.tostring(liq_mod, "#.##") + ")"
    table.cell(t, 0, 6, "Liquidity",
               text_color=color.new(color.gray, 20), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 6, liq_str,
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    // DTE guidance
    table.cell(t, 0, 7, dte_label,
               text_color=color.new(color.yellow, 10), text_halign=text.align_left, text_size=size.small)
    table.cell(t, 1, 7, asset_class,
               text_color=color.new(color.gray, 30), text_halign=text.align_right, text_size=size.small)

    // Score breakdown bar (visual)
    string breakdown = "L:" + str.tostring(loi_pts,"#") + " I:" + str.tostring(iv_pts,"#") + " D:" + str.tostring(dist_count,"#") + " M:" + (modifiers >= 0 ? "+" : "") + str.tostring(modifiers,"#.#")
    table.cell(t, 0, 8, breakdown,
               text_color=color.new(color.gray, 40), text_halign=text.align_left,  text_size=size.tiny)
    table.cell(t, 1, 8, "base " + str.tostring(base_score,"#.#"),
               text_color=color.new(color.gray, 40), text_halign=text.align_right, text_size=size.tiny)
