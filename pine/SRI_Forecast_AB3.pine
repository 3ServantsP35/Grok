// SRI Forecast AB3 — Strategic LEAP Accumulation (v4)
// P6 Framework — per-asset LOI thresholds and CT4 distribution overlay:
//
//   BTC-Proxy (MSTR/IBIT):       Acc=-60, Deep=-80, Trims=40/60/80
//   Business Momentum (TSLA):    Same as BTC-Proxy (driven by business cycle depth)
//   Trending (GLD):              Same as BTC-Proxy (structural trend depth)
//   MR-Large (SPY/QQQ):          Acc=-40, Deep=-60, Trims=10/30/50
//   MR-Small (IWM):              Same MR thresholds; CT3 = trim warning (not accumulate)
//
//   CT4 overlay: When CT4 fires on Momentum assets, distribution warning is shown.
//   IWM CT3: Treated as a trim prompt (late-cycle), not an accumulation signal.
//
// Colors: Deep green = deep accumulation, Green = accumulate, Gray = hold,
//         Yellow/Orange = trims approaching, Red = distribute/exit.
// Alerts: LOI threshold crossings only (confirmation ladder).
// © RizenShine — Forecast engine by CIO

//@version=6
indicator(title="SRI Forecast AB3 v5", shorttitle="SRI AB3", overlay=false, format=format.price, precision=1)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

string grp_mode = "Asset Classification"
string asset_class = input.string("Auto-Detect", "Asset Class",
    options=["Auto-Detect", "BTC-Proxy (MSTR/IBIT)", "Business Momentum (TSLA)", "Trending (GLD)", "MR-Large (SPY/QQQ)", "MR-Small (IWM)"],
    tooltip="Sets LOI thresholds and trim schedule. BTC-proxy: acc=-60, trims=40/60/80. MR: acc=-40, trims=10/30/50.",
    group=grp_mode)

string grp_core = "Core Settings"
int at_period   = input.int(14, "Trackline ATR Period", group=grp_core)
float at_coeff  = input.float(1.0, "Trackline ATR Coefficient", group=grp_core)

string grp_thresh = "Threshold Overrides"
float custom_acc      = input.float(0.0,  "Custom Acc Level (0 = use default)",      group=grp_thresh, tooltip="Override the accumulation threshold. Default: BTC-proxy=-45, MR=-40. Data analysis showed MSTR LOI min was -52.2 at $107 bottom — original -60 never triggered in Jul25-Feb26.")
float custom_deep_acc = input.float(0.0,  "Custom Deep Acc Level (0 = use default)", group=grp_thresh)
float custom_trim1    = input.float(0.0,  "Custom Trim 1 Level (0 = use default)",   group=grp_thresh)
float bounce_depth    = input.float(-35.0,"Min LOI Depth to Qualify Bounce",         group=grp_thresh, tooltip="LOI must reach this level before a bounce signal fires. Prevents false bounces in shallow dips. Data: Oct 2025 head-fakes were at LOI -22 to -26; Feb 2026 real bottom reached -52.")

string grp_loi = "LOI Weights"
float w_vlt  = input.float(40.0, "VLT SRIBI Weight",       group=grp_loi, minval=0, maxval=100)
float w_roc  = input.float(30.0, "VLT Acceleration Weight", group=grp_loi, minval=0, maxval=100)
float w_lt   = input.float(15.0, "LT SRIBI Weight",         group=grp_loi, minval=0, maxval=100)
float w_conc = input.float(15.0, "Concordance Weight",      group=grp_loi, minval=0, maxval=100)

string grp_pos = "Position Tracking"
float leap_strike = input.float(0.0, "LEAP Strike Price",      group=grp_pos)
float leap_entry  = input.float(0.0, "Entry Cost Per Contract", group=grp_pos)
int   leap_qty    = input.int(0,     "Number of Contracts",     group=grp_pos, minval=0)

string grp_disp = "Display"
bool show_table   = input.bool(true, "Show Info Table",     group=grp_disp)
bool show_legend  = input.bool(true, "Show Legend",         group=grp_disp)
bool show_zones   = input.bool(true, "Show Zone Background", group=grp_disp)
bool show_signals = input.bool(true, "Show Signal Markers", group=grp_disp)
bool show_ct4     = input.bool(true, "Show CT4 / IWM Warnings", group=grp_disp)

// ═══════════════════════════════════════════════════════════════
// ASSET CLASS AUTO-DETECT + THRESHOLDS
// ═══════════════════════════════════════════════════════════════

f_is_btc_proxy() =>
    string t = str.upper(syminfo.ticker)
    (syminfo.type == "crypto" or str.contains(t,"BTC") or str.contains(t,"MSTR") or
     str.contains(t,"IBIT") or str.contains(t,"GBTC") or str.contains(t,"BITO") or str.contains(t,"PURR"))

f_is_tsla() => str.upper(syminfo.ticker) == "TSLA"
f_is_gld()  =>
    string t = str.upper(syminfo.ticker)
    str.contains(t,"GLD") or str.contains(t,"IAU") or str.contains(t,"XAUUSD")
f_is_iwm()  =>
    string t = str.upper(syminfo.ticker)
    str.contains(t,"IWM") or str.contains(t,"RUT") or str.contains(t,"TNA")

string auto_class = f_is_tsla()      ? "Business Momentum (TSLA)" :
     f_is_btc_proxy() ? "BTC-Proxy (MSTR/IBIT)" :
     f_is_gld()       ? "Trending (GLD)" :
     f_is_iwm()       ? "MR-Small (IWM)" : "MR-Large (SPY/QQQ)"

string resolved_class = asset_class == "Auto-Detect" ? auto_class : asset_class

bool is_btc_proxy = resolved_class == "BTC-Proxy (MSTR/IBIT)"
bool is_tsla      = resolved_class == "Business Momentum (TSLA)"
bool is_gld       = resolved_class == "Trending (GLD)"
bool is_mr_large  = resolved_class == "MR-Large (SPY/QQQ)"
bool is_iwm       = resolved_class == "MR-Small (IWM)"
bool is_mr        = is_mr_large or is_iwm
bool is_momentum  = is_btc_proxy or is_tsla

// Per-asset LOI thresholds (with user override)
// BTC-proxy default lowered from -60 to -45 — data analysis (Jul25-Feb26) showed
// MSTR LOI min was -52.2 at the $106.96 absolute bottom; -60 never triggered.
float _def_acc      = is_mr ? -40.0 : -45.0
float _def_deep_acc = is_mr ? -60.0 : -65.0
float _def_trim1    = is_mr ? 10.0  : 40.0
float acc_level      = custom_acc      != 0.0 ? custom_acc      : _def_acc
float deep_acc_level = custom_deep_acc != 0.0 ? custom_deep_acc : _def_deep_acc
float trim1_level    = custom_trim1    != 0.0 ? custom_trim1    : _def_trim1
float trim2_level    = is_mr ? 30.0  : 60.0
float trim3_level    = is_mr ? 50.0  : 80.0
float trim_reset     = is_mr ? -10.0 : -20.0
float peak_roll      = is_mr ? 15.0  : 25.0

// ═══════════════════════════════════════════════════════════════
// TRACKLINES + SRIBI
// ═══════════════════════════════════════════════════════════════

f_trackline(int period, float coeff) =>
    atr = ta.rma(ta.tr(true), period)
    upT   = low  - atr * coeff
    downT = high + atr * coeff
    cond  = ta.rsi(close, period) >= 50
    var float track = 0.0
    track := cond ? math.max(upT, nz(track[1])) : math.min(downT, nz(track[1]))
    track

float vst_ftl  = request.security(syminfo.tickerid, "120", f_trackline(at_period, at_coeff))
float vst_stl  = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float vst_sribi = vst_stl != 0 ? (vst_ftl - vst_stl) / vst_stl * 100 : 0

float lt_ftl   = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float lt_stl   = request.security(syminfo.tickerid, "W",   f_trackline(at_period, at_coeff))
float lt_sribi  = lt_stl != 0 ? (lt_ftl - lt_stl) / lt_stl * 100 : 0

float st_ftl   = request.security(syminfo.tickerid, "240", f_trackline(at_period, at_coeff))
float st_stl   = request.security(syminfo.tickerid, "D",   f_trackline(at_period, at_coeff))
float st_sribi  = st_stl != 0 ? (st_ftl - st_stl) / st_stl * 100 : 0

float vlt_ftl  = request.security(syminfo.tickerid, "480", f_trackline(at_period, at_coeff))
float vlt_stl  = request.security(syminfo.tickerid, "2W",  f_trackline(at_period, at_coeff))
float vlt_sribi = vlt_stl != 0 ? (vlt_ftl - vlt_stl) / vlt_stl * 100 : 0

// 4-TF concordance — consistent with Python engine
int bull_count = (vst_sribi > 0 ? 1 : 0) + (st_sribi > 0 ? 1 : 0) + (lt_sribi > 0 ? 1 : 0) + (vlt_sribi > 0 ? 1 : 0)

// ═══════════════════════════════════════════════════════════════
// LOI COMPOSITE
// ═══════════════════════════════════════════════════════════════

float vlt_norm  = math.max(-100, math.min(100, vlt_sribi / 80 * 100))
float lt_norm   = math.max(-100, math.min(100, lt_sribi  / 80 * 100))
float conc_norm = (bull_count - 2.0) / 2.0 * 100   // 4-TF: range -100 to +100
float vlt_roc   = vlt_sribi - nz(vlt_sribi[10])
float roc_norm  = math.max(-100, math.min(100, vlt_roc / 40 * 100))

float total_w = w_vlt + w_roc + w_lt + w_conc
float loi = total_w > 0 ? (vlt_norm*w_vlt + roc_norm*w_roc + lt_norm*w_lt + conc_norm*w_conc) / total_w : 0

// ═══════════════════════════════════════════════════════════════
// CT4 OVERLAY (for Momentum assets and IWM CT3)
// ═══════════════════════════════════════════════════════════════

// CT from all 4 TFs (reuses ST already computed in tracklines section)
bool vst_pos = vst_sribi > 0
bool st_pos  = st_sribi  > 0
bool lt_pos  = lt_sribi  > 0
bool vlt_pos = vlt_sribi > 0
bool all_pos = vst_pos and st_pos and lt_pos and vlt_pos
int  ct_tier = all_pos and vlt_sribi > 20 ? 4 : all_pos ? 3 : vst_pos and lt_pos ? 2 : vst_pos and st_pos ? 1 : 0

bool ct4_active  = ct_tier == 4 and is_momentum
bool iwm_ct3_warn = ct_tier >= 3 and is_iwm

// ═══════════════════════════════════════════════════════════════
// ZONE CLASSIFICATION
// ═══════════════════════════════════════════════════════════════

string loi_zone = loi < deep_acc_level ? "DEEP ACCUM" :
     loi < acc_level                ? "ACCUMULATE" :
     loi < (is_mr ? -10.0 : -20.0) ? "Mild Opp"   :
     loi < (is_mr ?   5.0 :   0.0) ? "Neutral"     :
     loi < trim1_level              ? "Hold"        :
     loi < trim2_level              ? "Trim Watch"  :
     loi < trim3_level              ? "Trim Active" : "DISTRIBUTE"

// Background color by zone (vivid at extremes, fades in middle)
color zone_bg = ct4_active                     ? color.new(color.red, 80)    :
     iwm_ct3_warn                   ? color.new(color.orange, 82) :
     loi < deep_acc_level           ? color.new(#00FF00, 72)      :
     loi < acc_level                ? color.new(color.green, 80)  :
     loi < (is_mr ? -10.0 : -20.0) ? color.new(color.green, 92)  :
     loi < trim1_level              ? color(na)                   :
     loi < trim2_level              ? color.new(color.orange, 92) :
     loi < trim3_level              ? color.new(color.orange, 82) :
                                      color.new(color.red, 80)

// LOI line color
color loi_color = ct4_active ? color.new(color.red, 20) : loi < deep_acc_level ? color.new(#00FF00, 0) : loi < acc_level ? color.new(color.green, 0) : loi < trim1_level ? color.new(color.gray, 30) : loi < trim2_level ? color.new(color.orange, 30) : loi < trim3_level ? color.new(color.orange, 0) : color.new(color.red, 0)

// ═══════════════════════════════════════════════════════════════
// TRIM CYCLE TRACKING (state machine mirror)
// ═══════════════════════════════════════════════════════════════

var int trim_phase = 0
var float cycle_low = 0.0

if loi < trim_reset and nz(loi[1]) >= trim_reset
    trim_phase := 0
    cycle_low  := loi

if loi < cycle_low
    cycle_low := loi

bool trim1_cross = trim_phase < 1 and loi >= trim1_level and nz(loi[1]) < trim1_level
bool trim2_cross = trim_phase < 2 and loi >= trim2_level and nz(loi[1]) < trim2_level
bool trim3_cross = trim_phase < 3 and loi >= trim3_level and nz(loi[1]) < trim3_level

float loi_20max = ta.highest(loi, 20)
bool final_trim = trim_phase == 3 and loi_20max > trim3_level and
     (loi_20max - loi) > peak_roll and nz(loi_20max[1] - nz(loi[1])) <= peak_roll

if trim1_cross
    trim_phase := 1
if trim2_cross
    trim_phase := 2
if trim3_cross
    trim_phase := 3
if final_trim
    trim_phase := 4

string trim_status = switch trim_phase
    0 => "0% trimmed"
    1 => "25% trimmed"
    2 => "50% trimmed"
    3 => "75% trimmed"
    4 => "CLOSED"
    => ""

string next_trim = switch trim_phase
    0 => str.format("Trim 25% at LOI {0}", str.tostring(trim1_level,"#"))
    1 => str.format("Trim 50% at LOI {0}", str.tostring(trim2_level,"#"))
    2 => str.format("Trim 75% at LOI {0}", str.tostring(trim3_level,"#"))
    3 => str.format("Close on {0}pt rollover", str.tostring(peak_roll,"#"))
    4 => "Cycle complete"
    => ""

// ═══════════════════════════════════════════════════════════════
// ACCUMULATION SIGNALS — TWO-STAGE
//
// Stage 1 — Zone Entry (acc_enter / deep_enter):
//   LOI crosses below threshold. Awareness signal — not yet actionable.
//   Fires once per zone entry, regardless of direction.
//
// Stage 2 — Bottom Confirmation (acc_bounce / deep_bounce):
//   LOI was falling, now turns upward while still inside the zone.
//   This is the actionable buy signal. LOI was still falling when it
//   crossed the threshold — waiting for the turn fixes the blocking bug
//   where in_acc_zone = true prevented the old acc_new from ever firing.
// ═══════════════════════════════════════════════════════════════

bool in_acc_zone  = loi < acc_level
bool in_deep_zone = loi < deep_acc_level

// Stage 1: zone crossings
bool acc_enter  = ta.crossunder(loi, acc_level)
bool deep_enter = ta.crossunder(loi, deep_acc_level)

// Stage 2: bottom confirmation — 2-bar confirmed bounce with LOI depth filter
// Data finding: shallow bounces at LOI -22 to -26 (Oct 2025) were head-fakes;
// real bottom (Feb 2026, LOI -52) gave clean +25% recovery. Depth filter prevents noise.

// Track the lowest LOI reached while in the zone (resets when zone exits)
var float zone_loi_low = 0.0
if in_acc_zone and not nz(in_acc_zone[1])
    zone_loi_low := loi
else if in_acc_zone
    zone_loi_low := math.min(zone_loi_low, loi)
else
    zone_loi_low := 0.0

bool depth_ok = zone_loi_low <= bounce_depth     // zone must have reached min depth

// 2-bar rising confirmation: LOI rose on both this bar AND the previous bar,
// but 2 bars ago was still falling (genuine turn, not continuation of an existing rise)
bool loi_was_falling = nz(loi[2]) <= nz(loi[3])  // falling before the turn
bool loi_rose_bar1   = nz(loi[1]) > nz(loi[2])   // first rising bar
bool loi_rose_bar2   = loi > nz(loi[1])           // second rising bar (confirmation)
bool confirmed_bounce = loi_was_falling and loi_rose_bar1 and loi_rose_bar2

bool acc_bounce  = in_acc_zone  and confirmed_bounce and depth_ok
bool deep_bounce = in_deep_zone and confirmed_bounce and depth_ok

// IWM CT3 warning cross (signal fire even without LOI threshold)
bool iwm_ct3_cross = is_iwm and ct_tier >= 3 and nz(ct_tier[1]) < 3

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════

plot(loi, "LOI", color=loi_color, linewidth=2)
hline(0, "Zero", color=color.new(color.gray, 60), linestyle=hline.style_dotted)
plot(acc_level,      "Acc",      color=color.new(color.green, 50),  linewidth=1, style=plot.style_line)
plot(deep_acc_level, "Deep Acc", color=color.new(color.green, 30),  linewidth=1, style=plot.style_line)
plot(trim1_level,    "Trim 25%", color=color.new(color.orange, 50), linewidth=1, style=plot.style_line)
plot(trim2_level,    "Trim 50%", color=color.new(color.orange, 30), linewidth=1, style=plot.style_line)
plot(trim3_level,    "Trim 75%", color=color.new(color.red, 40),    linewidth=1, style=plot.style_line)

bgcolor(show_zones ? zone_bg : na)

// Signal markers
// Stage 1: Zone entry markers (triangle — awareness, not yet actionable)
plot(show_signals and acc_enter  and not deep_enter ? loi : na, "Acc Enter",  style=plot.style_triangledown, color=color.new(color.green, 20),  linewidth=2)
plot(show_signals and deep_enter                    ? loi : na, "Deep Enter", style=plot.style_triangledown, color=color.new(#00FF00, 10),       linewidth=2)
// Stage 2: Bottom confirmation (circle — actionable buy signal)
plot(show_signals and acc_bounce  and not deep_bounce ? loi : na, "Acc Bounce",  style=plot.style_circles, color=color.green, linewidth=3)
plot(show_signals and deep_bounce                     ? loi : na, "Deep Bounce", style=plot.style_circles, color=#00FF00,     linewidth=5)
plot(show_signals and trim1_cross ? loi : na, "Trim 25%", style=plot.style_cross,   color=color.orange,        linewidth=3)
plot(show_signals and trim2_cross ? loi : na, "Trim 50%", style=plot.style_cross,   color=color.new(color.red,30), linewidth=3)
plot(show_signals and trim3_cross ? loi : na, "Trim 75%", style=plot.style_circles, color=color.red,           linewidth=4)
plot(show_signals and final_trim  ? loi : na, "Exit 100%",style=plot.style_cross,   color=color.red,           linewidth=5)

// CT4 / IWM CT3 overlay
plot(show_ct4 and ct4_active ? loi : na, "CT4 Dist",   style=plot.style_circles, color=color.new(color.red,20), linewidth=4)
plot(show_ct4 and iwm_ct3_cross ? loi : na, "IWM Trim", style=plot.style_cross,  color=color.orange,            linewidth=3)

// ═══════════════════════════════════════════════════════════════
// POSITION CALCULATIONS
// ═══════════════════════════════════════════════════════════════

bool has_strike = leap_strike > 0
float intrinsic = has_strike ? math.max(0, close - leap_strike) : 0
float intrinsic_per_ct = intrinsic * 100
bool in_money = has_strike and close > leap_strike
bool has_entry = leap_entry > 0
float ct_pnl   = has_entry ? (intrinsic_per_ct - leap_entry) : 0
float pnl_pct  = has_entry and leap_entry != 0 ? ct_pnl / leap_entry * 100 : 0
bool has_qty   = leap_qty > 0
float total_pnl = has_qty ? ct_pnl * leap_qty : 0

// ═══════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════

var table t = table.new(position.bottom_right, 2, 17,
    bgcolor=color.new(color.black, 30), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast and show_table
    string class_short = is_btc_proxy ? "BTC-Proxy" : is_tsla ? "TSLA" : is_gld ? "GLD" : is_iwm ? "IWM" : "MR"
    string auto_tag    = asset_class == "Auto-Detect" ? "⚡" : ""

    color hdr_bg = ct4_active           ? color.new(color.red, 25)    :
         iwm_ct3_warn         ? color.new(color.orange, 30) :
         loi < deep_acc_level ? color.new(#00FF00, 25)      :
         loi < acc_level      ? color.new(color.green, 30)  :
         loi > trim3_level    ? color.new(color.red, 30)    :
         loi > trim2_level    ? color.new(color.orange, 30) : color.new(color.gray, 40)

    string hdr_str = ct4_active          ? "CT4 — DISTRIBUTION" :
         iwm_ct3_warn        ? "IWM CT3 — TRIM"  :
         loi < deep_acc_level ? "DEEP ACCUMULATE" :
         loi < acc_level      ? "ACCUMULATE"      :
         loi > trim3_level    ? "DISTRIBUTE"      :
         loi > trim2_level    ? "TRIM 50%→75%"    :
         loi > trim1_level    ? "TRIM ZONE"        : "HOLD"

    table.cell(t, 0, 0, str.format("AB3 {0}{1}", class_short, auto_tag), text_color=color.white, text_size=size.small, bgcolor=hdr_bg)
    table.cell(t, 1, 0, hdr_str, text_color=color.white, text_size=size.small, bgcolor=hdr_bg)

    // LOI
    color loi_clr = loi < deep_acc_level ? #00FF00 : loi < acc_level ? color.green : loi > trim3_level ? color.red : loi > trim1_level ? color.orange : color.gray
    table.cell(t, 0, 1, "LOI", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(loi, "#.#"), text_color=loi_clr, text_size=size.small)

    // Thresholds
    table.cell(t, 0, 2, "Acc / Deep", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, str.format("{0} / {1}", str.tostring(acc_level,"#"), str.tostring(deep_acc_level,"#")),
        text_color=color.green, text_size=size.tiny)
    table.cell(t, 0, 3, "Trims", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, str.format("{0} / {1} / {2}", str.tostring(trim1_level,"#"), str.tostring(trim2_level,"#"), str.tostring(trim3_level,"#")),
        text_color=color.orange, text_size=size.tiny)

    // Components
    table.cell(t, 0, 4, "  VLT", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(vlt_sribi,"#.#"), text_color=vlt_pos?color.teal:color.red, text_size=size.tiny)
    table.cell(t, 0, 5, "  VLT Accel", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(vlt_roc,"#.#"), text_color=vlt_roc>0?color.teal:color.red, text_size=size.tiny)
    table.cell(t, 0, 6, "  LT", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(lt_sribi,"#.#"), text_color=lt_pos?color.teal:color.red, text_size=size.tiny)

    // CT4 / IWM warning
    if ct4_active
        table.cell(t, 0, 7, "CT4 ⚠", text_color=color.red, text_size=size.tiny)
        table.cell(t, 1, 7, "VLT > +20, all TFs+. Do NOT add. Consider trim schedule.",
            text_color=color.red, text_size=size.tiny)
    else if iwm_ct3_warn
        table.cell(t, 0, 7, "IWM CT3 ⚠", text_color=color.orange, text_size=size.tiny)
        table.cell(t, 1, 7, "Late-cycle small-cap. Advance trim phase.",
            text_color=color.orange, text_size=size.tiny)
    else
        table.cell(t, 0, 7, "CT Tier",   text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 7, str.format("CT{0} ({1}/4 TFs+)", ct_tier, bull_count),
            text_color=color.gray, text_size=size.tiny)

    // Accumulation stage state
    string acc_stage_str = in_deep_zone and loi_now_rising ? "Stage 2 — Deep Bounce ●" :
         in_deep_zone  ? "Stage 1 — Deep zone (wait for turn)" :
         in_acc_zone and loi_now_rising ? "Stage 2 — Acc Bounce ●" :
         in_acc_zone   ? "Stage 1 — Acc zone (wait for turn)" :
         loi > trim1_level ? "Trim zone" : "Hold / Neutral"
    color acc_stage_clr = in_deep_zone and loi_now_rising ? #00FF00 :
         in_deep_zone  ? color.new(#00FF00, 40) :
         in_acc_zone and loi_now_rising ? color.green :
         in_acc_zone   ? color.new(color.green, 50) :
         loi > trim1_level ? color.orange : color.gray
    table.cell(t, 0, 8, "Acc Stage", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 8, acc_stage_str, text_color=acc_stage_clr, text_size=size.tiny)

    // Trim phase
    color trim_clr = trim_phase == 0 ? color.gray : trim_phase >= 3 ? color.red : color.orange
    table.cell(t, 0, 9, "Trim Phase", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 9, trim_status, text_color=trim_clr, text_size=size.tiny)
    table.cell(t, 0, 10, "Next",   text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 10, next_trim, text_color=color.white, text_size=size.tiny)

    // Position P&L
    int row = 11
    if has_strike
        table.cell(t, 0, row, "Strike",   text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, row, str.format("${0} ({1})", str.tostring(leap_strike,"#.##"), in_money?"ITM":"OTM"),
            text_color=in_money?color.green:color.red, text_size=size.tiny)
        row += 1
        table.cell(t, 0, row, "Intrinsic", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, row, str.format("${0}/ct", str.tostring(intrinsic_per_ct,"#.00")),
            text_color=intrinsic>0?color.green:color.gray, text_size=size.tiny)
        row += 1
    if has_entry
        table.cell(t, 0, row, "P&L/ct", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, row, str.format("${0} ({1}%)", str.tostring(ct_pnl,"#.00"), str.tostring(pnl_pct,"#.#")),
            text_color=pnl_pct>0?color.green:color.red, text_size=size.tiny)
        row += 1
    if has_qty
        table.cell(t, 0, row, "Total P&L", text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, row, str.format("${0}", str.tostring(total_pnl,"#,###.00")),
            text_color=total_pnl>0?color.green:color.red, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// LEGEND
// ═══════════════════════════════════════════════════════════════

var table leg = table.new(position.bottom_left, 2, 12,
    bgcolor=color.new(color.black, 25), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast and show_legend
    table.cell(leg, 0, 0, "AB3 v5", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 50))
    table.cell(leg, 1, 0, "Two-Stage Accumulation", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 50))
    // Stage 1 — zone entry (awareness)
    table.cell(leg, 0, 1, "▼ green",      text_color=color.green, text_size=size.tiny)
    table.cell(leg, 1, 1, "Stage 1: Acc zone entered (watch)",   text_color=color.gray, text_size=size.tiny)
    table.cell(leg, 0, 2, "▼ bright grn", text_color=#00FF00,    text_size=size.tiny)
    table.cell(leg, 1, 2, "Stage 1: Deep zone entered (watch)",  text_color=color.gray, text_size=size.tiny)
    // Stage 2 — bottom confirmation (actionable)
    table.cell(leg, 0, 3, "● green",      text_color=color.green, text_size=size.tiny)
    table.cell(leg, 1, 3, "Stage 2: Acc BOUNCE — buy signal",    text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 4, "● bright grn", text_color=#00FF00,    text_size=size.tiny)
    table.cell(leg, 1, 4, "Stage 2: Deep BOUNCE — high conviction", text_color=color.white, text_size=size.tiny)
    // Trim ladder
    table.cell(leg, 0, 5, "✕ orange",    text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 5, "Trim 25% / Trim 50%",                  text_color=color.gray,  text_size=size.tiny)
    table.cell(leg, 0, 6, "● red",        text_color=color.red,   text_size=size.tiny)
    table.cell(leg, 1, 6, "Trim 75%",                              text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 7, "✕ red (lg)",  text_color=color.red,   text_size=size.tiny)
    table.cell(leg, 1, 7, "Exit 100% (LOI rollover)",              text_color=color.white, text_size=size.tiny)
    // Warnings
    table.cell(leg, 0, 8, "● red (CT4)", text_color=color.red,   text_size=size.tiny)
    table.cell(leg, 1, 8, "CT4 distribution — Momentum assets",   text_color=color.white, text_size=size.tiny)
    table.cell(leg, 0, 9, "✕ orange IWM",text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 9, "IWM CT3 — advance trim phase",          text_color=color.gray,  text_size=size.tiny)
    // Thresholds
    table.cell(leg, 0, 10, "Lines",       text_color=color.gray,  text_size=size.tiny)
    table.cell(leg, 1, 10, "Solid=Deep/Trim75 | Plot=Acc/Trim25/50", text_color=color.gray, text_size=size.tiny)
    table.cell(leg, 0, 11, "BTC-proxy",   text_color=color.orange, text_size=size.tiny)
    table.cell(leg, 1, 11, "Acc:-60/-80  Trims:40/60/80  (MR:-40/-60/10/30/50)", text_color=color.gray, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
// ALERTS — CONFIRMATION LADDER ONLY
// ═══════════════════════════════════════════════════════════════

alertcondition(acc_enter, title="AB3 — Acc Zone Entered",
    message="AB3 Stage 1: LOI crossed into accumulation zone. Watch for bounce confirmation.")
alertcondition(deep_enter, title="AB3 — Deep Acc Zone Entered",
    message="AB3 Stage 1: LOI crossed into DEEP accumulation zone. High-conviction watch.")
alertcondition(acc_bounce, title="AB3 — Accumulate (Bottom Confirmed)",
    message="AB3 Stage 2: LOI turning up from accumulation zone. Bottom confirmation — scale into LEAPs.")
alertcondition(deep_bounce, title="AB3 — Deep Accumulate (Bottom Confirmed)",
    message="AB3 Stage 2: LOI turning up from DEEP zone. Highest-conviction entry signal. Rare event.")
alertcondition(trim1_cross, title="AB3 — Trim 25%",
    message="AB3 Ladder: LOI crossed Trim 1. Reduce position 25%.")
alertcondition(trim2_cross, title="AB3 — Trim 50%",
    message="AB3 Ladder: LOI crossed Trim 2. Reduce position 50%.")
alertcondition(trim3_cross, title="AB3 — Trim 75%",
    message="AB3 Ladder: LOI crossed Trim 3. Reduce position 75%.")
alertcondition(final_trim,  title="AB3 — Exit 100%",
    message="AB3 Ladder: LOI rolling over from peak. Close remaining position.")
alertcondition(loi < trim_reset and nz(loi[1]) >= trim_reset, title="AB3 — Cycle Reset",
    message="AB3: Cycle reset. New accumulation cycle may begin.")
alertcondition(ct4_active and nz(ct_tier[1]) < 4, title="AB3 — CT4 Distribution Warning",
    message="AB3 WARNING: CT4 on Momentum asset. VLT > +20. Advance trim phase; do not add.")
alertcondition(iwm_ct3_cross, title="AB3 — IWM CT3 Trim Prompt",
    message="AB3 IWM: CT3 reached (late-cycle small-cap). Consider advancing trim to next phase.")
