// ═══════════════════════════════════════════════════════════════
// ALERTS — CONFIRMATION LADDER + QQQ-SPECIFIC
// ═══════════════════════════════════════════════════════════════

alertcondition(ct1_cross, title="AB1 — CT1 Step",
    message="AB1 Ladder: CT1 reached (MIXED context, VST+ST+). BTC-proxy sweet spot.")
alertcondition(ct2_cross and not is_qqq and not is_spy, title="AB1 — CT2 Step",
    message="AB1 Ladder: CT2 reached (early structural, LT turning).")
alertcondition(ct3_cross, title="AB1 — CT3 Step",
    message="AB1 Ladder: CT3 reached (all TFs+). TSLA entry confirmed. BTC-proxy LT has caught up.")
alertcondition(ct4_cross and is_momentum, title="AB1 — CT4 Distribution",
    message="AB1 WARNING: CT4 on Momentum asset. VLT extended — distribution signal. Do not enter; consider AB3 trim.")
alertcondition(is_iwm and ct3_cross, title="AB1 — IWM CT3 Warning",
    message="AB1 IWM: CT3 reached — late-cycle small-cap trap (30% win). Not an AB1 entry. Check AB3 trim schedule.")
alertcondition(qqq_primary_entry, title="AB1 — QQQ Primary Entry",
    message="AB1 QQQ: LT just flipped positive with ST already positive — primary entry signal (70% win rate at 10%/360bars).")
alertcondition(qqq_caution, title="AB1 — QQQ LOI Caution",
    message="AB1 QQQ: LOI rolling over above +20. Not an exit signal, but monitor your position.")
bool was_favorable = cond_favorable[1]
alertcondition(ct_stepped_down and was_favorable, title="AB1 — Condition Lost",
    message="AB1: Favorable CT level dropped. Reassess entry.")
