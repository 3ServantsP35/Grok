// BTC 50 SMA MTF — Bitcoin 50-Period SMA on Any Chart
// Always displays the 50 SMA of BTC regardless of the current ticker (MSTR, IBIT, SPY, etc.).
// Multi-timeframe selectable (same pattern as MTF_SMA and AB4 Entry Gate).
// Useful for Rule 9 defensive signal (BTC below 50 SMA elevates bearish weight).
// © RizenShine — BTC structural layer for CIO SRI engine

//@version=6
indicator("BTC 50 SMA MTF", shorttitle="BTC SMA50", overlay=true, max_bars_back=2000)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_btc = "BTC Settings"
i_btc_symbol = input.string("BTCUSD", "BTC Symbol", group=grp_btc)   // Change if needed (e.g. BINANCE:BTCUSDT)
i_length     = input.int(50, "SMA Length", minval=5, maxval=200, group=grp_btc)
i_src        = input.source(close, "Source (on BTC)", group=grp_btc)

grp_tf = "Timeframe"
i_tf = input.string("D", "Timeframe", 
     options=["Auto (Current)", "1", "3", "5", "15", "30", "45", "60", "120", "180", "240", "D", "W", "M"], 
     group=grp_tf)

// ═══════════════════════════════════════════════════════════════
// TIMEFRAME & BTC SMA CALCULATION
// ═══════════════════════════════════════════════════════════════
tf = i_tf == "Auto (Current)" ? timeframe.period : i_tf

btc_sma = request.security(i_btc_symbol, tf, ta.sma(i_src, i_length))

// ═══════════════════════════════════════════════════════════════
// PLOT
// ═══════════════════════════════════════════════════════════════
plot(btc_sma, "BTC 50 SMA", color=color.new(color.fuchsia, 0), linewidth=2)

// Optional status
above_btc_sma = close > btc_sma
below_btc_sma = close < btc_sma

bgcolor(above_btc_sma ? color.new(color.green, 92) : na)
bgcolor(below_btc_sma ? color.new(color.red, 92) : na)

// Info table
var table t = table.new(position.top_right, 2, 2, bgcolor=color.new(color.black, 70))
table.cell(t, 0, 0, "BTC 50 SMA", text_color=color.gray)
table.cell(t, 1, 0, str.tostring(btc_sma, format.mintick), text_color=color.fuchsia)
table.cell(t, 0, 1, "Status", text_color=color.gray)
table.cell(t, 1, 1, above_btc_sma ? "Above" : below_btc_sma ? "Below" : "—", 
     text_color=above_btc_sma ? color.green : below_btc_sma ? color.red : color.gray)
